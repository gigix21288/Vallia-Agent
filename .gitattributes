# Keep LF line endings in the repo. The agent runs on Linux and CRLF would
# break the shebang of install.sh / vallia-agent.init ("bad interpreter ^M").
* text=auto eol=lf

# Be explicit for the executable scripts.
*.sh         text eol=lf
*.py         text eol=lf
*.init       text eol=lf
Makefile     text eol=lf
vallia-agent.init text eol=lf
