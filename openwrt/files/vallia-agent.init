#!/bin/sh /etc/rc.common
# procd init script for the Vallia Agent on OpenWrt.
START=95
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    # To require a shared token, append:  --token YOURTOKEN
    # (set the SAME token in the app → Settings → Agent token)
    procd_set_param command /usr/bin/python3 /opt/vallia-agent/vallia_agent.py --mode pcap
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
